# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="YOUR_APP_URL"

# EmailJS Account 1 (Signup)
VITE_EMAILJS_SERVICE_ID_1=YOUR_SERVICE_ID_1
VITE_EMAILJS_TEMPLATE_ID_SIGNUP_USER_1=YOUR_TEMPLATE_ID_SIGNUP_USER_1
VITE_EMAILJS_TEMPLATE_ID_SIGNUP_ADMIN_1=YOUR_TEMPLATE_ID_SIGNUP_ADMIN_1
VITE_EMAILJS_PUBLIC_KEY_1=YOUR_PUBLIC_KEY_1

# EmailJS Account 2 (Login)
VITE_EMAILJS_SERVICE_ID_2=YOUR_SERVICE_ID_2
VITE_EMAILJS_TEMPLATE_ID_LOGIN_USER_2=YOUR_TEMPLATE_ID_LOGIN_USER_2
VITE_EMAILJS_TEMPLATE_ID_LOGIN_ADMIN_2=YOUR_TEMPLATE_ID_LOGIN_ADMIN_2
VITE_EMAILJS_PUBLIC_KEY_2=YOUR_PUBLIC_KEY_2

# EmailJS Account 3 (Order)
VITE_EMAILJS_SERVICE_ID_3=YOUR_SERVICE_ID_3
VITE_EMAILJS_TEMPLATE_ID_ORDER_USER_3=YOUR_TEMPLATE_ID_ORDER_USER_3
VITE_EMAILJS_TEMPLATE_ID_ORDER_ADMIN_3=YOUR_TEMPLATE_ID_ORDER_ADMIN_3
VITE_EMAILJS_PUBLIC_KEY_3=YOUR_PUBLIC_KEY_3
